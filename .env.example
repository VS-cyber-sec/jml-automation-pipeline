# ============================================================
# JML Automation Pipeline — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub — it is in .gitignore
#
# In Auth0 Actions, secrets are stored in the Secrets panel
# (🔑 icon) and accessed via event.secrets — NOT from this file
# This file is for local reference and documentation only
# ============================================================

# ── Auth0 Configuration ──────────────────────────────────────
# Your Auth0 tenant domain
# Format: dev-xxxx.us.auth0.com
# NO https:// prefix — NO trailing slash
AUTH0_DOMAIN=dev-xxxx.us.auth0.com

# Machine-to-Machine app credentials
# Create at: Applications → + Create Application → Machine to Machine
# Authorize for: Auth0 Management API
# Permissions: read:users, update:users, read:roles, create:role_members
MGMT_CLIENT_ID=your_m2m_client_id_here
MGMT_CLIENT_SECRET=your_m2m_client_secret_here

# ── Role IDs ─────────────────────────────────────────────────
# Find Role ID in URL after creating:
# manage.auth0.com/.../roles/rol_XXXXXXXXXX
#                             ^^^^^^^^^^^^ copy this part
ROLE_ID_ALL_EMPLOYEES=rol_XXXXXXXXXX
ROLE_ID_ENGINEERING=rol_XXXXXXXXXX
ROLE_ID_HR_FINANCE=rol_XXXXXXXXXX

# ── Slack ─────────────────────────────────────────────────────
# Create at: api.slack.com/apps → Incoming Webhooks → Add to Workspace
# Format: https://hooks.slack.com/services/T.../B.../XXXXXXXX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── Google Sheets ─────────────────────────────────────────────
# Spreadsheet ID from URL:
# docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
#                                 ^^^^^^^^^^^^^^ copy this
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# API Key from Google Cloud Console:
# console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable: Google Sheets API
GOOGLE_API_KEY=AIzaSy_your_api_key_here
